{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["@upstash/context7-mcp"],
      "description": "Up-to-date library docs for LLMs — auto-resolves versions"
    },
    "github": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_PAT"
      },
      "description": "GitHub API — repos, issues, PRs, actions, code search"
    },
    "docker": {
      "command": "docker",
      "args": ["mcp", "gateway", "run"],
      "description": "Docker MCP Toolkit — requires Docker Desktop 4.62+"
    },
    "codebase-memory": {
      "command": "npx",
      "args": ["-y", "codebase-memory-mcp"],
      "description": "Persistent codebase knowledge graph"
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest", "--headless"],
      "description": "Playwright browser automation"
    },
    "vercel": {
      "command": "npx",
      "args": ["-y", "next-devtools-mcp@latest"],
      "description": "Vercel / Next.js DevTools — deployment, logs"
    },
    "mcphub": {
      "type": "http",
      "url": "http://localhost:3000/mcp",
      "description": "MCPHub — manage multiple MCP servers via HTTP dashboard"
    }
  }
}
